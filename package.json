{
  "name": "@bkincz/drift",
  "version": "1.2.0",
  "type": "module",
  "description": "A DOM-driven form library that automatically tracks forms and fields based on their presence in the DOM.",
  "author": "Benjamin Kinczel <beni.kinczel@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bkincz/drift.git"
  },
  "bugs": {
    "url": "https://github.com/bkincz/drift/issues"
  },
  "homepage": "https://github.com/bkincz/drift#readme",
  "main": "./dist/drift.umd.cjs",
  "module": "./dist/drift.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/drift.js",
      "require": "./dist/drift.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@bkincz/clutch": "^1.2.0"
  },
  "devDependencies": {
    "@bkincz/clutch": "^1.2.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.6.5",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "npm:rolldown-vite@7.2.5",
    "vite-plugin-dts": "^4.5.1",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "vite-plugin-dts>vite": "npm:rolldown-vite@7.2.5"
    }
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "15 KB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "15 KB"
    }
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
